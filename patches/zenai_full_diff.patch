+def _handle_swarm_post(handler, action, payload):
+    """Dispatch /__swarm/* POST endpoints to swarm_bridge."""
+    if not _swarm or not _SWARM_OK:
+        handler._send_json(503, {"error": "Swarm bridge unavailable"})
